# ─── AI Edit: Token ───────────────────────────────────────────────
# Set this to use an explicit API key. If not set, the app will
# auto-detect from: macOS Keychain → ~/.claude/.credentials.json
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── AI Edit: Model Override ─────────────────────────────────────
# First match wins. If none are set, defaults to claude-sonnet-4-20250514
# CLAUDE_MODEL=
# CLAUDE_CODE_MODEL=
# ANTHROPIC_MODEL=
# ANTHROPIC_DEFAULT_MODEL=
